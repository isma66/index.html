<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="VTC Confort">
    <title>VTC Confort</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #000;
            color: #fff;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, #1DB954, #1aa34a);
            padding: 28px 20px;
            text-align: center;
        }

        .header h1 {
            font-size: 28px;
            margin-bottom: 6px;
        }

        .header p {
            font-size: 13px;
            opacity: 0.9;
        }

        /* Onglets */
        .tabs {
            display: flex;
            background: #111;
            padding: 12px;
            gap: 12px;
        }

        .tab {
            flex: 1;
            padding: 12px;
            background: #222;
            border: none;
            color: #fff;
            font-size: 16px;
            font-weight: 600;
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.2s;
        }

        .tab.active {
            background: #1DB954;
            color: #000;
        }

        /* Pages */
        .page {
            display: none;
            flex: 1;
            overflow-y: auto;
        }

        .page.active {
            display: block;
        }

        /* Page Musique */
        .music-container {
            padding: 20px;
        }

        .login-btn {
            background: #1DB954;
            text-align: center;
            padding: 16px;
            border-radius: 50px;
            font-weight: bold;
            font-size: 18px;
            cursor: pointer;
            margin: 20px 0;
        }

        .login-btn:active {
            opacity: 0.8;
        }

        .search-box {
            display: flex;
            gap: 10px;
            margin: 20px 0;
        }

        .search-box input {
            flex: 1;
            padding: 14px 18px;
            background: #222;
            border: none;
            border-radius: 50px;
            color: white;
            font-size: 16px;
        }

        .search-box button {
            padding: 14px 24px;
            background: #1DB954;
            border: none;
            border-radius: 50px;
            font-weight: bold;
            font-size: 16px;
            cursor: pointer;
        }

        .result-item {
            background: #1e1e1e;
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: background 0.2s;
        }

        .result-item:active {
            background: #2c2c2c;
        }

        .result-item strong {
            font-size: 16px;
        }

        .result-item div {
            font-size: 13px;
            color: #1DB954;
            margin-top: 4px;
        }

        .current-track {
            text-align: center;
            margin-top: 20px;
            padding: 12px;
            background: #111;
            border-radius: 50px;
            color: #1DB954;
            font-size: 14px;
        }

        /* Page Menu */
        .menu-container {
            padding: 20px;
        }

        .menu-section {
            margin-bottom: 30px;
        }

        .menu-section h2 {
            font-size: 22px;
            margin-bottom: 15px;
            color: #ffd966;
            border-left: 4px solid #ffd966;
            padding-left: 12px;
        }

        .menu-item {
            background: #1e1e1e;
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .menu-item h3 {
            font-size: 17px;
            margin-bottom: 4px;
        }

        .menu-item p {
            font-size: 12px;
            color: #aaa;
        }

        .price {
            font-size: 18px;
            font-weight: bold;
            color: #ffd966;
        }

        .qr-box {
            background: white;
            padding: 24px;
            border-radius: 24px;
            text-align: center;
            margin-top: 20px;
        }

        .qr-box p {
            color: #000;
            margin-bottom: 15px;
            font-weight: bold;
        }

        #qrcode {
            display: flex;
            justify-content: center;
        }

        .footer {
            text-align: center;
            padding: 20px;
            color: #666;
            font-size: 11px;
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs2-fix/dist/qrcode.min.js"></script>
</head>
<body>

<div class="header">
    <h1>🍽️ VTC CONFORT</h1>
    <p>Musique & Pause Gourmande à bord</p>
</div>

<div class="tabs">
    <button class="tab active" onclick="showPage('music')">🎵 MUSIQUE</button>
    <button class="tab" onclick="showPage('menu')">🍹 MENU</button>
</div>

<!-- PAGE MUSIQUE -->
<div id="music-page" class="page active">
    <div class="music-container">
        <div id="login-section">
            <div class="login-btn" onclick="loginSpotify()">
                🔐 Se connecter à Spotify
            </div>
        </div>
        <div id="player-section" style="display: none;">
            <div class="search-box">
                <input type="text" id="searchInput" placeholder="Artiste ou chanson... (ex: Daft Punk, Ninho)">
                <button onclick="searchTrack()">Chercher</button>
            </div>
            <div id="results"></div>
            <div id="current-track" class="current-track"></div>
        </div>
    </div>
</div>

<!-- PAGE MENU -->
<div id="menu-page" class="page">
    <div class="menu-container">
        <!-- BOISSONS -->
        <div class="menu-section">
            <h2>💧 BOISSONS</h2>
            <div class="menu-item">
                <div><h3>Eau</h3><p>Bouteille 50cl • Fraîche</p></div>
                <div class="price">2€</div>
            </div>
            <div class="menu-item">
                <div><h3>Oasis</h3><p>33cl • Fruité</p></div>
                <div class="price">3€</div>
            </div>
            <div class="menu-item">
                <div><h3>Coca-Cola</h3><p>33cl • Frais</p></div>
                <div class="price">3€</div>
            </div>
            <div class="menu-item">
                <div><h3>Jus d'orange</h3><p>25cl • Pur jus</p></div>
                <div class="price">3€</div>
            </div>
        </div>

        <!-- CONFORT -->
        <div class="menu-section">
            <h2>⚡ CONFORT & ÉNERGIE</h2>
            <div class="menu-item">
                <div><h3>Besoin d'énergie</h3><p>Barre céréales</p></div>
                <div class="price">2€</div>
            </div>
            <div class="menu-item">
                <div><h3>Café</h3><p>Expresso • Allongé</p></div>
                <div class="price">2,50€</div>
            </div>
            <div class="menu-item">
                <div><h3>Pain au chocolat</h3><p>Viennoiserie</p></div>
                <div class="price">2,50€</div>
            </div>
        </div>

        <!-- PAIEMENT -->
        <div class="qr-box">
            <p>💳 Paiement rapide & sans contact</p>
            <div id="qrcode"></div>
            <p style="color:#666; font-size:11px; margin-top:12px;">Scannez pour régler</p>
        </div>
        <div class="footer">
            🚗 À votre service | CB, Apple Pay, Google Pay
        </div>
    </div>
</div>

<script>
    // ⚠️ CONFIGURATION SPOTIFY
    const CLIENT_ID = "2dbc54425c7410f940310f2989e45f5";
    const REDIRECT_URI = "https://ismaa66.github.io/Vtc-confort/callback.html";
    
    let accessToken = null;

    // Changement d'onglet
    function showPage(page) {
        const musicPage = document.getElementById('music-page');
        const menuPage = document.getElementById('menu-page');
        const tabs = document.querySelectorAll('.tab');
        
        if (page === 'music') {
            musicPage.classList.add('active');
            menuPage.classList.remove('active');
            tabs[0].classList.add('active');
            tabs[1].classList.remove('active');
        } else {
            menuPage.classList.add('active');
            musicPage.classList.remove('active');
            tabs[1].classList.add('active');
            tabs[0].classList.remove('active');
        }
    }

    // Connexion Spotify
    function loginSpotify() {
        const scope = "user-read-playback-state user-modify-playback-state streaming";
        const authUrl = `https://accounts.spotify.com/authorize?client_id=${CLIENT_ID}&response_type=token&redirect_uri=${encodeURIComponent(REDIRECT_URI)}&scope=${encodeURIComponent(scope)}`;
        window.location.href = authUrl;
    }

    // Récupérer le token après connexion
    function getTokenFromURL() {
        const hash = window.location.hash.substring(1);
        const params = new URLSearchParams(hash);
        const token = params.get('access_token');
        
        if (token) {
            accessToken = token;
            localStorage.setItem('spotify_token', token);
            document.getElementById('login-section').style.display = 'none';
            document.getElementById('player-section').style.display = 'block';
            window.history.pushState("", "", window.location.pathname);
        } else {
            const savedToken = localStorage.getItem('spotify_token');
            if (savedToken) {
                accessToken = savedToken;
                document.getElementById('login-section').style.display = 'none';
                document.getElementById('player-section').style.display = 'block';
            }
        }
    }

    // Rechercher une musique
    async function searchTrack() {
        const query = document.getElementById('searchInput').value.trim();
        if (!query) return;
        if (!accessToken) {
            document.getElementById('results').innerHTML = '<div style="text-align:center; color:#ff6b6b;">🔐 Veuillez vous reconnecter</div>';
            return;
        }
        
        document.getElementById('results').innerHTML = '<div style="text-align:center;">🔍 Recherche...</div>';
        
        try {
            const response = await fetch(`https://api.spotify.com/v1/search?q=${encodeURIComponent(query)}&type=track&limit=10`, {
                headers: { 'Authorization': `Bearer ${accessToken}` }
            });
            
            if (response.status === 401) {
                localStorage.removeItem('spotify_token');
                document.getElementById('login-section').style.display = 'block';
                document.getElementById('player-section').style.display = 'none';
                document.getElementById('results').innerHTML = '';
                return;
            }
            
            const data = await response.json();
            const resultsDiv = document.getElementById('results');
            resultsDiv.innerHTML = '';
            
            if (data.tracks && data.tracks.items.length > 0) {
                data.tracks.items.forEach(track => {
                    const div = document.createElement('div');
                    div.className = 'result-item';
                    div.innerHTML = `<strong>${escapeHtml(track.name)}</strong><div>${track.artists.map(a => a.name).join(', ')}</div>`;
                    div.onclick = () => playTrack(track.uri);
                    resultsDiv.appendChild(div);
                });
            } else {
                resultsDiv.innerHTML = '<div style="text-align:center; color:#888;">Aucun résultat</div>';
            }
        } catch (error) {
            document.getElementById('results').innerHTML = '<div style="text-align:center; color:#ff6b6b;">Erreur réseau</div>';
        }
    }

    // Lancer la musique
    async function playTrack(uri) {
        const trackDiv = document.getElementById('current-track');
        trackDiv.innerHTML = '🎵 Lancement...';
        
        try {
            const response = await fetch('https://api.spotify.com/v1/me/player/play', {
                method: 'PUT',
                headers: { 
                    'Authorization': `Bearer ${accessToken}`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ uris: [uri] })
            });
            
            if (response.ok) {
                trackDiv.innerHTML = '🎵 En cours de lecture !';
                setTimeout(() => { trackDiv.innerHTML = ''; }, 3000);
            } else if (response.status === 404) {
                trackDiv.innerHTML = '⚠️ Ouvrez Spotify sur l\'iPad une fois, puis réessayez';
            } else {
                trackDiv.innerHTML = '❌ Erreur, reconnectez-vous';
            }
        } catch (error) {
            trackDiv.innerHTML = '❌ Erreur de connexion';
        }
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // QR Code
    function makeQR() {
        const qrDiv = document.getElementById('qrcode');
        if (qrDiv && typeof QRCode !== 'undefined') {
            qrDiv.innerHTML = '';
            new QRCode(qrDiv, {
                text: "https://paypal.me/votrecompte",
                width: 150,
                height: 150
            });
        }
    }

    // Touche Entrée
    document.getElementById('searchInput')?.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') searchTrack();
    });

    // Initialisation
    window.addEventListener('load', () => {
        getTokenFromURL();
        makeQR();
    });
</script>

</body>
</html>
